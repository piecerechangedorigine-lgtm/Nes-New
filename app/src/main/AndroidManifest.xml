<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!--
      POST_NOTIFICATIONS is the one runtime permission this app requests
      — added in Phase 8.5 alongside the Permission Center, and only
      because Profile's push-notification toggle is a real, working
      feature it backs. Every other permission the Permission Center
      tracks (SMS, Camera, OCR, Widgets, Background Sync) has no
      manifest entry on purpose: those back future features that don't
      exist yet (see PermissionType's doc comment), and this app never
      requests a runtime permission with no feature behind it.

      allowBackup="false" already fully disables both cloud (Auto Backup)
      and device-to-device transfer on Android 12+, so a separate
      dataExtractionRules/fullBackupContent file would be redundant here —
      only add one if allowBackup is ever turned back on.
    -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <application
        android:name=".NovaApplication"
        android:allowBackup="false"
        android:enableOnBackInvokedCallback="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.Nova">

        <!--
          Disables WorkManager's default self-initialization — without
          this, WorkManagerInitializer runs before NovaApplication.onCreate()
          and crashes with a double-initialization error the moment
          NovaApplication also calls WorkManager.initialize() via its
          Configuration.Provider implementation. This is the standard,
          documented AndroidX pattern for on-demand/Hilt-driven
          WorkManager initialization, not a Nova-specific workaround.
        -->
        <provider
            android:name="androidx.startup.InitializationProvider"
            android:authorities="${applicationId}.androidx-startup"
            android:exported="false"
            tools:node="merge">
            <meta-data
                android:name="androidx.work.WorkManagerInitializer"
                android:value="androidx.startup"
                tools:node="remove" />
        </provider>

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:theme="@style/Theme.Nova.Splash">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!--
          Phase 9.9 home screen widgets. All three are Glance
          (Jetpack Compose-for-widgets) — there is no separate
          registration surface for "lock screen widgets" (Phase 9.10):
          Android has no public lock-screen-widget API since API 21
          removed keyguard widgets, so any OEM launcher/lock-screen
          surface that does support widgets consumes these same
          standard AppWidgetProvider entries. See
          DASHBOARD_ARCHITECTURE.md for the full explanation.
        -->
        <receiver
            android:name=".widget.GoalProgressWidgetReceiver"
            android:exported="true"
            android:label="@string/app_name">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/goal_progress_widget_info" />
        </receiver>

        <receiver
            android:name=".widget.ForecastWidgetReceiver"
            android:exported="true"
            android:label="@string/app_name">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/forecast_widget_info" />
        </receiver>

        <receiver
            android:name=".widget.FinancialSnapshotWidgetReceiver"
            android:exported="true"
            android:label="@string/app_name">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/financial_snapshot_widget_info" />
        </receiver>

    </application>

</manifest>
