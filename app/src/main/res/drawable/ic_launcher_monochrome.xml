<?xml version="1.0" encoding="utf-8"?>
<!--
  Monochrome adaptive-icon layer (Android 13+ themed/Material You icons).
  The system extracts alpha from this and applies its own tint, so color
  here is irrelevant beyond opaque-vs-transparent — using the single-N
  mono mark (brand/logo/nova-mark-mono-light.svg), not the two-color
  overlap, since themed icons are rendered as a flat single tone and the
  overlap reads as noise at that point.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <path
        android:pathData="M30,28 L30,80 L78,28 L78,80"
        android:fillColor="#00000000"
        android:strokeColor="#FF000000"
        android:strokeWidth="14"
        android:strokeLineCap="round"
        android:strokeLineJoin="round" />
</vector>
