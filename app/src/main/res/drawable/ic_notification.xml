<?xml version="1.0" encoding="utf-8"?>
<!--
  Status bar notification icon. Android requires this to be a flat,
  fully-opaque-or-transparent white silhouette — the system replaces
  whatever color is set here with its own tint at draw time, and any
  gradient/opacity/anti-aliased edge gets flattened harshly. Single N,
  no overlap, heavier relative stroke than the launcher mark since this
  renders as small as 24dp.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="24dp"
    android:height="24dp"
    android:viewportWidth="24"
    android:viewportHeight="24"
    android:tint="#FFFFFFFF">

    <path
        android:pathData="M6.5,6.5 L6.5,17.5 L17.5,6.5 L17.5,17.5"
        android:fillColor="#00000000"
        android:strokeColor="#FFFFFFFF"
        android:strokeWidth="2.6"
        android:strokeLineCap="round"
        android:strokeLineJoin="round" />
</vector>
