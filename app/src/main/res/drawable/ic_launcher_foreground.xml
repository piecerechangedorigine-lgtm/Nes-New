<?xml version="1.0" encoding="utf-8"?>
<!--
  Adaptive icon foreground. This is a direct port of brand/logo/nova-mark.svg
  — same 108x108 grid, same path data, same two-pass overlap. If the mark
  in brand/logo/nova-mark.svg ever changes, mirror the change here; there
  is no build-time SVG-to-vector pipeline wired up yet, so the two files
  are kept in sync by hand.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- First N: base weight, full opacity, indigo -->
    <path
        android:pathData="M26,24 L26,76 L74,24 L74,76"
        android:fillColor="#00000000"
        android:strokeColor="#5B6CFF"
        android:strokeWidth="14"
        android:strokeLineCap="round"
        android:strokeLineJoin="round" />

    <!-- Second N: mirrored + offset, mint, layered on top at reduced opacity -->
    <path
        android:pathData="M72,34 L72,86 L24,34 L24,86"
        android:fillColor="#00000000"
        android:strokeColor="#9FE8D6"
        android:strokeAlpha="0.78"
        android:strokeWidth="14"
        android:strokeLineCap="round"
        android:strokeLineJoin="round" />
</vector>
