<?xml version="1.0" encoding="utf-8"?>
<!--
  Adaptive icon background. Solid Nova background with a faint radial
  lift toward Elevated at the center — visible mainly on the round/squircle
  masks where edges get cropped, giving the foreground mark subtle depth
  instead of sitting on a flat plate. Never put content here; masking
  crops this layer unpredictably across launchers.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <path android:pathData="M0,0h108v108h-108z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:type="radial"
                android:centerX="54"
                android:centerY="54"
                android:gradientRadius="76"
                android:startColor="#1F1F27"
                android:endColor="#0B0B10" />
        </aapt:attr>
    </path>
</vector>
