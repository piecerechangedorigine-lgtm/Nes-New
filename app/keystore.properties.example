# Copy this file to `keystore.properties` (same directory) and fill in
# real values. `keystore.properties` is gitignored — never commit it or
# the .jks/.keystore file it points to.
#
# Generate a release keystore once, per app, and store it somewhere
# durable outside the repo (password manager + encrypted backup — losing
# it means you can never publish an update under the same app listing):
#
#   keytool -genkey -v -keystore nova-release.keystore \
#     -alias nova -keyalg RSA -keysize 2048 -validity 10000

storeFile=/absolute/path/to/nova-release.keystore
storePassword=CHANGE_ME
keyAlias=nova
keyPassword=CHANGE_ME
